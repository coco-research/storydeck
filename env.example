# Rijul's Stories — local environment TEMPLATE
# Copy this file to `.env` (which is gitignored) and fill in your key:
#     cp env.example .env
# The server reads .env at startup via src/env.js (no external dependency).

# Required to enable the AI assistant (POST /api/chat). Without it the ask bar
# returns a graceful 503 and the rest of the board works normally.
# Get one from Cursor -> Settings -> API Keys. Starts with "key_".
CURSOR_API_KEY=

# Optional: pin the model instead of auto-resolving a Sonnet model.
# AI_MODEL=
