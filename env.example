# StoryDeck — local environment TEMPLATE
# Copy this file to `.env` (which is gitignored) and fill in your values:
#     cp env.example .env
# The server reads .env at startup via src/env.js (no external dependency).

# ── AI assistant (optional) ──────────────────────────────────────────────────
# The ask bar works with ANY ONE of these providers. Set the key for the one you
# want; if several are set, the first in this order wins: OpenAI, Anthropic,
# Cursor. Without any key the ask bar returns a graceful 503 and the rest of the
# board works offline.

# OpenAI (https://platform.openai.com/api-keys) — starts with "sk-".
OPENAI_API_KEY=

# Anthropic / Claude (https://console.anthropic.com/) — starts with "sk-ant-".
ANTHROPIC_API_KEY=

# Cursor (Cursor -> Settings -> API Keys) — starts with "key_".
CURSOR_API_KEY=

# Optional: force a specific provider instead of auto-detecting.
#   one of: openai | anthropic | cursor
# AI_PROVIDER=openai

# Optional: pin the model. Defaults per provider:
#   openai=gpt-4o-mini, anthropic=claude-sonnet-5, cursor=auto
# AI_MODEL=

# ── Branding (optional) ──────────────────────────────────────────────────────
# Custom board title (header + window). Defaults to "StoryDeck".
# BOARD_TITLE=StoryDeck
