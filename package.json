{
  "name": "storydeck",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "description": "StoryDeck — a local-first, retro-terminal Kanban board backed by on-device SQLite. No cloud; optional AI assistant (OpenAI / Anthropic / Cursor).",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "app": "electron .",
    "mcp": "node src/mcp/server.js",
    "test": "node --test",
    "manifest": "node tools/make-manifest.cjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --arm64"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "build": {
    "appId": "com.storydeck.app",
    "productName": "StoryDeck",
    "asarUnpack": [
      "src/mcp/**",
      "node_modules/@modelcontextprotocol/**",
      "node_modules/zod/**"
    ],
    "artifactName": "StoryDeck-${version}-${os}-${arch}.${ext}",
    "files": [
      "main.js",
      "src/**/*",
      "web/**/*",
      "data/seed.sample.json",
      "content-manifest.json",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "coco-research",
      "repo": "storydeck"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  }
}
